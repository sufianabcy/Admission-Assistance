# ── Groq API ──────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Data & Storage paths (optional overrides) ─────────────────
# Default values shown — only set to override
DATA_PATH=./data/colleges.json
CHROMA_PATH=./chroma_db
 
# ── Generic placeholders for common deployments (optional) ──
# These are included for portability across hosting providers.
# Only GROQ_API_KEY is required for this project.
API_KEY=your_api_key_here
DATABASE_URL=your_database_url_here
SECRET_KEY=your_secret_here
PORT=5000
